{
  "manifest_version": 3,
  "name": "Wasabi Saver",
  "version": "1.0.0",
  "description": "Save any landing page (HTML + desktop/mobile screenshots) into your Wasabi archive, into a folder with tags.",
  "permissions": ["activeTab", "scripting", "tabs", "storage", "debugger"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Save this page to Wasabi",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["config.js", "content-session-sync.js"],
      "run_at": "document_idle"
    }
  ]
}
