{
  "manifest_version": 3,
  "name": "Wasabi Saver",
  "version": "1.3.0",
  "description": "Save landing pages (HTML + screenshots) to your Wasabi archive, and save images/videos as creatives into a project's Competitor Library.",
  "permissions": ["activeTab", "scripting", "tabs", "storage", "debugger"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Save this page to Wasabi",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["config.js", "content-session-sync.js", "content-creative.js"],
      "run_at": "document_idle"
    }
  ]
}
