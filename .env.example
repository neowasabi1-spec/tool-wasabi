# =====================================================
# FUNNEL SWIPER DASHBOARD — ENVIRONMENT VARIABLES
# =====================================================
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local to version control.
# =====================================================

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Security (SOC 2) ---
# Secret used to authenticate internal API calls and dashboard access.
# Generate with: openssl rand -hex 32
DASHBOARD_API_SECRET=

# Comma-separated list of allowed CORS origins (production URLs)
ALLOWED_ORIGINS=https://your-dashboard.vercel.app,https://your-domain.com

# --- AI API Keys ---
ANTHROPIC_API_KEY=
GOOGLE_GEMINI_API_KEY=
OPENAI_API_KEY=

# --- External Services ---
AGENTIC_BROWSER_API_URL=http://localhost:8000
CHECKOUT_CHAMP_LOGIN_ID=
CHECKOUT_CHAMP_PASSWORD=

# --- OpenClaw Worker (locale) ---
# Base URL del deploy Netlify a cui openclaw-worker.js deve parlare
# (sia per fetchare i job pending che per gli endpoint /api/swipe/*).
# Se non settata, usa il default https://cute-cupcake-74bad8.netlify.app
TOOL_BASE_URL=https://cute-cupcake-74bad8.netlify.app

# --- MCP Server ---
# Fallback API key usata da bundle-mcp quando il client non manda
# X-API-Key. Va settata su Netlify (NON in .env.local committato).
# Genera una key con prefisso "fsk_" e mettila qui:
MCP_DEFAULT_API_KEY=

# --- Build ---
# Set to 'true' only for Docker/Fly.io self-hosting
STANDALONE=false
